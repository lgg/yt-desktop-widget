{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YTM Desktop Widget",
  "version": "../package.json",
  "identifier": "io.github.lgg.ytm-desktop-widget",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:31420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "YTM Desktop Widget",
        "width": 336,
        "height": 438,
        "minWidth": 252,
        "minHeight": 270,
        "maxWidth": 504,
        "maxHeight": 1170,
        "resizable": false,
        "fullscreen": false,
        "maximized": false,
        "visible": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false
      },
      {
        "label": "settings",
        "title": "YTM Desktop Widget Settings",
        "width": 720,
        "height": 760,
        "minWidth": 620,
        "minHeight": 680,
        "resizable": false,
        "visible": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "windows": {
      "timestampUrl": ""
    }
  }
}
