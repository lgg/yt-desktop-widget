{
  "name": "ytm-desktop-widget",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A premium Windows desktop widget for YTMDesktop powered by Tauri v2, React, TypeScript, and the Companion Server API.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:desktop": "tauri dev",
    "build": "tsc -b && vite build",
    "build:desktop": "tauri build --no-bundle",
    "build:portable": "npm run build:desktop",
    "preview": "vite preview --host 127.0.0.1 --port 34173",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 34174",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run test && npm run build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.1.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.7",
    "vitest": "^3.2.4"
  }
}
